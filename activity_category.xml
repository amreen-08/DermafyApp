<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="5dp"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:layout_marginBottom="25dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8BC34A"
            android:layout_marginEnd="15dp"/>

        <TextView
            android:id="@+id/tvSelectCatTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Category"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:padding="5dp"
            android:background="@android:drawable/dialog_holo_light_frame"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="10dp"
        android:layout_marginBottom="15dp">
        <Button
            android:id="@+id/btnCleansers"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:text="Cleansers"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="#F08080" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="10dp"
        android:layout_marginBottom="15dp">
        <Button
            android:id="@+id/btnMoisturizers"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:text="Moisturizers"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="#7A66A4" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="10dp"
        android:layout_marginBottom="15dp">
        <Button
            android:id="@+id/btnSerums"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:text="Serums"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="#A1B3D6" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="10dp"
        android:layout_marginBottom="15dp">
        <Button
            android:id="@+id/btnSunscreen"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:text="Sunscreen"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="#81D4FA" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose a category to view products"
            android:textColor="#888888"
            android:textSize="16sp"/>
    </LinearLayout>

</LinearLayout>